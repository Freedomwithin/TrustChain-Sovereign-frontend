# TrustChain-Sovereign: Frontend Configuration (Vite)

# The URL where your TrustChain Sentinel Backend is running
# Use http://localhost:3001 for local testing
VITE_API_BASE_URL=http://localhost:3001

# The Solana RPC URL for Devnet (Used for wallet balance/history checks)
VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Set to 'true' to use simulated data if backend/RPC is unavailable
VITE_MOCK_MODE=false

# TARGET_WALLET_ADDRESS: The default profile to display (GAZD fallback)
VITE_TARGET_WALLET=GAZDwoHW6x4QCaWXizhckqta6v7nFYEFg2aULTk52k7b
